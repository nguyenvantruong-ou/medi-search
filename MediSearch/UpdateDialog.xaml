<Window x:Class="MediSearch.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediSearch Update" Height="360" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#17202A" TextWrapping="Wrap" />
            <TextBlock x:Name="MessageText" Margin="0,14,0,0" FontSize="15" Foreground="#344054" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,18" Background="White" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="8" Padding="14">
            <TextBox x:Name="ReleaseNotesBox"
                     IsReadOnly="True"
                     BorderThickness="0"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="White" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="LaterButton" Content="Later" MinWidth="104" Padding="14,9" Margin="0,0,10,0" Click="LaterButton_Click" />
            <Button x:Name="UpdateButton" Content="Download Update" MinWidth="140" Padding="14,9" Background="#0F766E" Foreground="White" BorderThickness="0" Click="UpdateButton_Click" />
        </StackPanel>
    </Grid>
</Window>
