<Window x:Class="MediSearch.UpdateToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="340" Height="132"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Border Background="White" BorderBrush="#B9E6FE" BorderThickness="1" CornerRadius="8" Padding="14" MouseLeftButtonUp="Toast_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="32" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Có phiên bản mới" FontSize="16" FontWeight="Bold" Foreground="#0F766E" />
                <TextBlock x:Name="VersionText" Margin="0,6,0,0" FontSize="13" Foreground="#344054" TextWrapping="Wrap" />
                <TextBlock Text="Click để cập nhật tự động" Margin="0,8,0,0" FontSize="12" Foreground="#667085" />
            </StackPanel>
            <Button Grid.Column="1" Content="x" Width="28" Height="28" Padding="0" VerticalAlignment="Top" Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
